int main() {
    int total_seconds;
    cout << "Enter total seconds: ";
    cin >> total_seconds;

    int hours = total_seconds / 3600;
    int minutes = (total_seconds % 3600) / 60;
    int seconds = total_seconds % 60;

    cout << total_seconds << " seconds is " << hours << " hours, " 
         << minutes << " minutes, and " << seconds << " seconds." << endl;
    return 0;
}

