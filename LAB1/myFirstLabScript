    cout << "x1 and y1: "; cin >> x1 >> y1;
    cout << "x2 and y2: "; cin >> x2 >> y2;

    double distance = sqrt(pow(x2 - x1, 2) + pow(y2 - y1, 2));
    cout << "Distance: " << distance << endl;
    return 0;
}

