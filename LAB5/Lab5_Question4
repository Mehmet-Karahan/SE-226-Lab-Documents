#include <iostream>
using namespace std;

double power(double r, int n) {
    if (n == 0)
        return 1;
    return r * power(r, n - 1);
}

double compute_gn(int n, double r) {
    if (n == 0)
        return 1;
    return compute_gn(n - 1, r) + power(r, n);
}

int main() {
    int n;
    double r;
    cout << "Please enter n: ";
    cin >> n;
    cout << "Please enter r: ";
    cin >> r;
    cout << "G" << n << " = " << compute_gn(n, r) << endl;
    return 0;
}
